#!/usr/bin/env python3
"""ollie-fleetctl — stable management verbs for the Ollie/Hermes stack.

Invoked over SSH by the Ollie Fleet dashboard. Contract: every verb prints
exactly one JSON object to stdout and exits 0, or {"error": "..."} and exits
non-zero. Long verbs (agents create, update) stream NDJSON events ending in
{"event": "done"} or {"event": "error"}. `backup` is the one exception: it
streams a raw tarball to stdout. stderr is human-only; Fleet never parses it.

Installed by scripts/10-install-fleetctl.sh. Versioned with the stack on
purpose: the verb names are the stable contract, the implementation follows
whatever the current install scripts set up.
"""

import argparse
import json
import os
import shutil
import subprocess
import sys
import tempfile
import time
import urllib.error
import urllib.request

VERSION = "1.0.0"

HOME = os.path.expanduser("~")
HERMES_DIR = os.path.join(HOME, ".hermes")
PROFILES_DIR = os.path.join(HERMES_DIR, "profiles")
STACK_DIR = os.environ.get("HERMES_STACK_DIR", os.path.join(HOME, "hermes-stack"))
COMPOSE_FILE = os.path.join(STACK_DIR, "docker-compose.yml")
INSTALL_DIR = os.environ.get("OLLIE_INSTALL_DIR", os.path.join(HOME, "ollie-hermes-install"))
ORCH_DIR = os.path.join(HOME, "ollie-hermes-orchestrator")
ORCH_URL = os.environ.get("ORCH_URL", "http://localhost:9123")
ORCH_ENV = os.environ.get("ORCH_ENV", os.path.join(HOME, ".config", "ollie-orchestrator", ".env"))
FLEET_ENV = os.environ.get("FLEET_ENV", os.path.join(HOME, ".config", "ollie-fleet", ".env"))


# ---------------------------------------------------------------- plumbing

def emit(obj):
    """Print the verb's single JSON result object."""
    print(json.dumps(obj))


def fail(msg, code=1):
    """Print {"error": ...} and exit non-zero."""
    print(json.dumps({"error": msg}))
    sys.exit(code)


def event(**kw):
    """Print one NDJSON progress event (flushed so SSH relays it live)."""
    print(json.dumps(kw), flush=True)


def run_cmd(args, timeout=30, input_text=None):
    """Run a command; return (rc, stdout, stderr). Never raises on non-zero."""
    try:
        p = subprocess.run(args, capture_output=True, text=True,
                           timeout=timeout, input=input_text)
        return p.returncode, p.stdout, p.stderr
    except FileNotFoundError:
        return 127, "", "%s: not found" % args[0]
    except subprocess.TimeoutExpired:
        return 124, "", "%s: timed out after %ss" % (args[0], timeout)


def read_env_file(path):
    """Parse KEY=VALUE lines (quotes stripped); missing file -> {}."""
    env = {}
    try:
        with open(path, encoding="utf-8") as f:
            for line in f:
                line = line.strip()
                if not line or line.startswith("#") or "=" not in line:
                    continue
                k, _, v = line.partition("=")
                k = k.strip()
                if not k:
                    continue
                env[k] = v.strip().strip("'\"")
    except OSError:
        pass
    return env


# ------------------------------------------------------- orchestrator client

def orch_key():
    key = read_env_file(ORCH_ENV).get("ORCHESTRATOR_KEY", "")
    if not key:
        raise RuntimeError("no ORCHESTRATOR_KEY in %s" % ORCH_ENV)
    return key


def orch_request(method, path, body=None, timeout=30):
    """JSON request to the local orchestrator -> (status, parsed_or_None, raw)."""
    req = urllib.request.Request(
        ORCH_URL + path, method=method,
        data=json.dumps(body).encode() if body is not None else None,
        headers={"Authorization": "Bearer " + orch_key(),
                 "Content-Type": "application/json"})
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            raw = resp.read().decode()
            return resp.status, (json.loads(raw) if raw.strip() else None), raw
    except urllib.error.HTTPError as e:
        return e.code, None, e.read().decode(errors="replace")
    except urllib.error.URLError as e:
        return None, None, str(e)


def orch_stream(method, path, body, timeout=600):
    """Send a request and relay the orchestrator's SSE stream as NDJSON.
    Returns the last event object (or None if the stream was empty)."""
    req = urllib.request.Request(
        ORCH_URL + path, method=method,
        data=json.dumps(body).encode() if body is not None else None,
        headers={"Authorization": "Bearer " + orch_key(),
                 "Content-Type": "application/json"})
    last = None
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            for line in resp:
                line = line.decode().strip()
                if not line.startswith("data:"):
                    continue
                try:
                    obj = json.loads(line[5:].strip())
                except ValueError:
                    continue
                last = obj
                event(**obj)
    except urllib.error.HTTPError as e:
        body = e.read().decode(errors="replace")[:200]
        last = {"event": "error", "error": "orchestrator HTTP %s: %s" % (e.code, body)}
        event(**last)
    except (urllib.error.URLError, OSError) as e:
        last = {"event": "error", "error": "orchestrator unreachable: %s" % e}
        event(**last)
    return last


# ----------------------------------------------------------- health collectors

def _read_file(path):
    with open(path) as f:
        return f.read()


def _proc_stat_cpu():
    """-> (idle_ticks, total_ticks) from the aggregate cpu line."""
    nums = [int(x) for x in _read_file("/proc/stat").splitlines()[0].split()[1:]]
    idle = nums[3] + (nums[4] if len(nums) > 4 else 0)
    return idle, sum(nums)


def get_cpu_percent():
    i1, t1 = _proc_stat_cpu()
    time.sleep(0.25)
    i2, t2 = _proc_stat_cpu()
    dt = t2 - t1
    return round(100 * (1 - (i2 - i1) / dt)) if dt > 0 else 0


def get_memory_mb():
    """-> (used_mb, total_mb) using MemAvailable semantics."""
    info = {}
    for line in _read_file("/proc/meminfo").splitlines():
        k, _, v = line.partition(":")
        if v.strip():
            info[k.strip()] = int(v.strip().split()[0])  # kB
    total = info.get("MemTotal", 0) // 1024
    avail = info.get("MemAvailable", 0) // 1024
    if not info.get("MemAvailable"):
        raise RuntimeError("MemAvailable missing from /proc/meminfo")
    return total - avail, total


def get_system():
    used_mb, total_mb = get_memory_mb()
    du = shutil.disk_usage("/")
    return {
        "cpuPercent": get_cpu_percent(),
        "ramUsedMb": used_mb,
        "ramTotalMb": total_mb,
        "diskUsedGb": round(du.used / 1e9, 1),
        "diskTotalGb": round(du.total / 1e9, 1),
    }


def get_units():
    rc, out, err = run_cmd(["systemctl", "--user", "list-units", "--all",
                            "--no-legend", "--plain",
                            "hermes-*", "ollie-orchestrator*"])
    if rc != 0:
        raise RuntimeError("systemctl failed: %s" % err.strip())
    units = []
    for line in out.splitlines():
        parts = line.split()
        if len(parts) >= 3 and parts[0].endswith(".service"):
            units.append({"unit": parts[0], "active": parts[2]})
    return units


def get_containers():
    rc, out, err = run_cmd(["docker", "compose", "-f", COMPOSE_FILE,
                            "ps", "-a", "--format", "json"])
    if rc != 0:
        raise RuntimeError("docker compose ps failed: %s" % err.strip())
    stripped = out.strip()
    if not stripped:
        return []
    if stripped.startswith("["):  # compose v2.21+ emits a single JSON array
        items = json.loads(stripped)
    else:  # older compose emits one JSON object per line
        items = [json.loads(l) for l in stripped.splitlines() if l.strip()]
    return [{"name": c.get("Service", ""), "state": c.get("State", ""),
             "status": c.get("Status", "")} for c in items]


def get_versions():
    versions = {"fleetctl": VERSION}
    rc, out, _ = run_cmd(["hermes", "--version"], timeout=15)
    versions["hermes"] = out.strip() if rc == 0 and out.strip() else "unknown"
    return versions


def get_agents_summary():
    status, parsed, raw = orch_request("GET", "/v1/agents")
    if status != 200:
        raise RuntimeError("orchestrator /v1/agents returned HTTP %s: %s" % (status, raw[:200]))
    if parsed is None:
        raise RuntimeError("orchestrator /v1/agents: empty body")
    return parsed.get("agents", [])


def build_health():
    health = {"fleetctlVersion": VERSION,
              "collectedAt": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())}
    errors = []
    _mod = sys.modules.get(__name__) if __name__ != "__main__" else sys.modules.get("__main__")
    _gdict = _mod.__dict__ if _mod is not None else globals()
    for key, name in (("system", "get_system"), ("units", "get_units"),
                      ("containers", "get_containers"), ("versions", "get_versions"),
                      ("agents", "get_agents_summary")):
        try:
            health[key] = _gdict[name]()
        except Exception as e:  # collectors degrade independently
            health[key] = None
            errors.append("%s: %s" % (key, e))
    health["errors"] = errors
    return health


def cmd_health(args):
    emit(build_health())


def _payload(args):
    """JSON body from --json or stdin."""
    raw = args.json if args.json is not None else sys.stdin.read()
    try:
        return json.loads(raw)
    except ValueError as e:
        fail("invalid JSON payload: %s" % e, 2)


def cmd_agents(args):
    if args.action == "list":
        status, parsed, raw = orch_request("GET", "/v1/agents")
        if status != 200 or parsed is None:
            fail("orchestrator HTTP %s: %s" % (status, raw[:200]))
        emit(parsed)
    elif args.action == "get":
        status, parsed, raw = orch_request("GET", "/v1/agents/%s" % args.id)
        if status != 200 or parsed is None:
            fail("orchestrator HTTP %s: %s" % (status, raw[:200]))
        emit(parsed)
    elif args.action == "create":
        last = orch_stream("POST", "/v1/agents", _payload(args))
        if not last or last.get("event") != "done":
            sys.exit(1)
    elif args.action == "update":
        status, parsed, raw = orch_request("PATCH", "/v1/agents/%s" % args.id, _payload(args))
        if status != 200:
            fail("orchestrator HTTP %s: %s" % (status, raw[:200]))
        emit(parsed if parsed is not None else {"updated": args.id})
    elif args.action == "delete":
        status, _, raw = orch_request("DELETE", "/v1/agents/%s" % args.id)
        if status not in (204, 404):  # delete is idempotent
            fail("orchestrator HTTP %s: %s" % (status, raw[:200]))
        emit({"deleted": args.id})
    elif args.action == "set-identity":
        status, parsed, raw = orch_request("POST", "/v1/agents/%s/identity" % args.id, _payload(args))
        if status != 200:
            fail("orchestrator HTTP %s: %s" % (status, raw[:200]))
        emit(parsed if parsed is not None else {"ok": True})


DOCKER_SERVICES = {"cortex": "cortex", "frontend": "dashboard"}


def resolve_target(target):
    """Map a restart/logs target -> (systemd_units, compose_services).
    Raises ValueError for unknown targets."""
    if target == "stack":
        units = [u["unit"] for u in get_units()]
        return units, ["cortex", "dashboard"]
    if target in DOCKER_SERVICES:
        return [], [DOCKER_SERVICES[target]]
    if target == "orchestrator":
        return ["ollie-orchestrator.service"], []
    for base in ("gateway", "dashboard"):
        if target == base:
            return ["hermes-%s.service" % base], []
        if target.startswith(base + "-"):
            return ["hermes-%s.service" % target], []
    raise ValueError("unknown target: %s (expected gateway[-name], dashboard[-name], "
                     "orchestrator, cortex, frontend, or stack)" % target)


def cmd_restart(args):
    try:
        units, services = resolve_target(args.target)
    except ValueError as e:
        fail(str(e), 2)
    results = []
    for u in units:
        rc, _, err = run_cmd(["systemctl", "--user", "restart", u], timeout=60)
        results.append({"target": u, "ok": rc == 0,
                        "error": err.strip() or "exit %s" % rc if rc != 0 else None})
    for s in services:
        rc, _, err = run_cmd(["docker", "compose", "-f", COMPOSE_FILE,
                              "restart", s], timeout=120)
        results.append({"target": "compose:%s" % s, "ok": rc == 0,
                        "error": err.strip() or "exit %s" % rc if rc != 0 else None})
    emit({"restarted": results})
    if not all(r["ok"] for r in results):
        sys.exit(1)


def cmd_logs(args):
    if args.service == "stack":
        fail("'stack' is not a valid logs target; specify a single service", 2)
    if args.service in DOCKER_SERVICES:
        rc, out, err = run_cmd(["docker", "compose", "-f", COMPOSE_FILE, "logs",
                                "--no-color", "--tail", str(args.lines),
                                DOCKER_SERVICES[args.service]], timeout=30)
    else:
        try:
            units, _ = resolve_target(args.service)
        except ValueError as e:
            fail(str(e), 2)
        rc, out, err = run_cmd(["journalctl", "--user", "-u", units[0],
                                "-n", str(args.lines), "--no-pager",
                                "-o", "short-iso"], timeout=30)
    if rc != 0:
        fail("logs failed for %s: %s" % (args.service, err.strip()))
    emit({"service": args.service, "lines": out.splitlines()})


def _step_cmd(args_list, timeout, input_text=None):
    """Run one update step -> (ok, short_detail)."""
    rc, out, err = run_cmd(args_list, timeout=timeout, input_text=input_text)
    return rc == 0, (err.strip() or out.strip())[-500:]


def cmd_update(args):
    component = args.component
    steps = []
    if component in ("hermes", "all"):
        steps += [
            ("git-pull-install-repo", ["git", "-C", INSTALL_DIR, "pull", "--ff-only"], 120),
            ("hermes-update", ["hermes", "update"], 900),
            # hermes update resets ~/.hermes/hermes-agent — re-apply the stack pieces it wipes:
            ("reinstall-cortex-plugin", ["bash", os.path.join(INSTALL_DIR, "scripts", "04-install-cortex-plugin.sh")], 300),
            ("repatch-cron-brain", ["bash", os.path.join(INSTALL_DIR, "scripts", "07-patch-cron-brain.sh")], 120),
            ("reinstall-souls", ["bash", os.path.join(INSTALL_DIR, "scripts", "08-install-souls.sh")], 120),
        ]
    if component in ("stack", "all"):
        steps += [
            ("compose-pull", ["docker", "compose", "-f", COMPOSE_FILE, "pull"], 600),
            ("compose-up", ["docker", "compose", "-f", COMPOSE_FILE, "up", "-d"], 300),
        ]
    if component in ("orchestrator", "all"):
        steps += [
            ("git-pull-orchestrator", ["git", "-C", ORCH_DIR, "pull", "--ff-only"], 120),
            ("pip-install", [os.path.join(ORCH_DIR, ".venv", "bin", "pip"),
                             "install", "-q", "-r",
                             os.path.join(ORCH_DIR, "requirements.txt")], 600),
            ("restart-orchestrator", ["systemctl", "--user", "restart", "ollie-orchestrator"], 60),
        ]
    for name, cmd_args, timeout in steps:
        event(event="progress", step=name)
        # hermes update prompts interactively (same CLI behavior 02-install-hermes.sh
        # works around by piping "y"); answer yes so it can't hang to the timeout.
        ok, detail = _step_cmd(cmd_args, timeout,
                               input_text="y\ny\ny\ny\ny\n" if name == "hermes-update" else None)
        if not ok:
            event(event="error", step=name, error=detail)
            sys.exit(1)
    event(event="done", component=component)


def post_json(url, token, payload, timeout=15):
    """POST JSON with a bearer token -> HTTP status (raises on network or HTTP error)."""
    req = urllib.request.Request(
        url, method="POST", data=json.dumps(payload).encode(),
        headers={"Authorization": "Bearer " + token,
                 "Content-Type": "application/json"})
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        return resp.status


def collect_backup_paths():
    """Files worth preserving: session DBs, configs, personas, OAuth tokens."""
    paths = []
    for rel in ("state.db", "config.yaml", "SOUL.md", "auth.json"):
        p = os.path.join(HERMES_DIR, rel)
        if os.path.isfile(p):
            paths.append(p)
    if os.path.isdir(PROFILES_DIR):
        for prof in sorted(os.listdir(PROFILES_DIR)):
            for rel in ("state.db", "config.yaml", "SOUL.md"):
                p = os.path.join(PROFILES_DIR, prof, rel)
                if os.path.isfile(p):
                    paths.append(p)
    return paths


def cmd_backup(args):
    if sys.stdout.isatty():
        fail("backup streams a tarball; redirect stdout "
             "(e.g. ollie-fleetctl backup > backup.tgz)", 2)
    staging = tempfile.mkdtemp(prefix="fleet-backup-")
    try:
        # Cortex DB snapshot via sqlite's online .backup (best-effort; the
        # container may be down — the rest of the backup still proceeds).
        run_cmd(["docker", "exec", "cortex", "sqlite3", "/data/cortex.db",
                 ".backup /data/cortex-snapshot.db"], timeout=120)
        run_cmd(["docker", "cp", "cortex:/data/cortex-snapshot.db", staging],
                timeout=120)
        paths = collect_backup_paths()
        snap = os.path.join(staging, "cortex-snapshot.db")
        if os.path.isfile(snap):
            paths.append(snap)
        if not paths:
            fail("nothing to back up (no state.db/config/SOUL files found)")
        rc = subprocess.call(["tar", "czf", "-", "--absolute-names"] + paths,
                             stdout=sys.stdout.buffer if hasattr(sys.stdout, "buffer") else sys.stdout)
        sys.exit(rc)
    finally:
        shutil.rmtree(staging, ignore_errors=True)


def cmd_heartbeat(args):
    env = read_env_file(FLEET_ENV)
    url, token = env.get("FLEET_URL", ""), env.get("FLEET_TOKEN", "")
    if not url or not token:
        # Pre-enrollment no-op: the timer is installed before the box is enrolled.
        emit({"skipped": "not enrolled (%s lacks FLEET_URL/FLEET_TOKEN)" % FLEET_ENV})
        return
    payload = {"health": build_health()}
    try:
        status = post_json(url.rstrip("/") + "/heartbeat", token, payload)
        emit({"posted": True, "status": status})
    except urllib.error.HTTPError as e:
        fail("heartbeat rejected: HTTP %s" % e.code)
    except (urllib.error.URLError, OSError) as e:
        fail("heartbeat failed: %s" % e)


# -------------------------------------------------------------------- main

def main(argv=None):
    p = argparse.ArgumentParser(prog="ollie-fleetctl",
                                description="Management verbs for the Ollie/Hermes stack")
    sub = p.add_subparsers(dest="verb", required=True)
    sub.add_parser("version", help="fleetctl version")
    sub.add_parser("health", help="one-shot stack health snapshot (JSON)")
    a = sub.add_parser("agents", help="agent CRUD via the local orchestrator")
    a.add_argument("action", choices=["list", "get", "create", "update",
                                      "delete", "set-identity"])
    a.add_argument("id", nargs="?", help="agent id (required except for list/create)")
    a.add_argument("--json", help="JSON payload; omit to read from stdin")
    r = sub.add_parser("restart", help="restart a service or the whole stack")
    r.add_argument("target",
                   help="gateway[-name] | dashboard[-name] | orchestrator | cortex | frontend | stack")
    l = sub.add_parser("logs", help="recent logs for one service")
    l.add_argument("service", help="same targets as restart (except stack)")
    l.add_argument("-n", "--lines", type=int, default=200)
    u = sub.add_parser("update", help="update stack components (streams NDJSON progress)")
    u.add_argument("component", nargs="?", default="all",
                   choices=["hermes", "stack", "orchestrator", "all"])
    sub.add_parser("heartbeat", help="POST health to the fleet dashboard (no-op until enrolled)")
    sub.add_parser("backup", help="stream a tarball of state DBs, configs, and personas")

    args = p.parse_args(argv)
    if args.verb == "version":
        emit({"fleetctl": VERSION})
    elif args.verb == "health":
        cmd_health(args)
    elif args.verb == "agents":
        if args.action in ("get", "update", "delete", "set-identity") and not args.id:
            p.error("agents %s requires an agent id" % args.action)
        cmd_agents(args)
    elif args.verb == "restart":
        cmd_restart(args)
    elif args.verb == "logs":
        cmd_logs(args)
    elif args.verb == "update":
        cmd_update(args)
    elif args.verb == "heartbeat":
        cmd_heartbeat(args)
    elif args.verb == "backup":
        cmd_backup(args)


if __name__ == "__main__":
    main()
