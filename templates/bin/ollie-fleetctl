#!/usr/bin/env python3
"""ollie-fleetctl — stable management verbs for the Ollie/Hermes stack.

Invoked over SSH by the Ollie Fleet dashboard. Contract: every verb prints
exactly one JSON object to stdout and exits 0, or {"error": "..."} and exits
non-zero. Long verbs (agents create, update) stream NDJSON events ending in
{"event": "done"} or {"event": "error"}. `backup` is the one exception: it
streams a raw tarball to stdout. stderr is human-only; Fleet never parses it.

Installed by scripts/10-install-fleetctl.sh. Versioned with the stack on
purpose: the verb names are the stable contract, the implementation follows
whatever the current install scripts set up.
"""

import argparse
import json
import os
import shutil
import subprocess
import sys
import tempfile
import time
import urllib.error
import urllib.request

VERSION = "1.1.0"
# Identify ourselves explicitly. The urllib default ("Python-urllib/x.y") is
# flagged by Cloudflare's managed bot heuristics even with Bot Fight Mode off,
# which 403s the heartbeat POST before it reaches Fleet. A named UA passes.
USER_AGENT = "ollie-fleetctl/" + VERSION

CONTROL_POLL_SECONDS = 60
MIN_INTERVAL_MINUTES = 5
MAX_INTERVAL_MINUTES = 720
DEFAULT_INTERVAL_MINUTES = 30

HOME = os.path.expanduser("~")
HERMES_DIR = os.path.join(HOME, ".hermes")
PROFILES_DIR = os.path.join(HERMES_DIR, "profiles")
DEFAULT_GATEWAY_PORT = 8642
DEFAULT_DASHBOARD_PORT = 9119
GATEWAY_BASE_PORT = 8643    # first named-profile gateway port
DASHBOARD_BASE_PORT = 9121  # first named-profile dashboard port (9120 = cortex)
VENV_PYTHON = os.path.join(os.path.expanduser("~"), ".hermes", "hermes-agent", "venv", "bin", "python")
SYSTEMD_USER_DIR = os.path.join(os.path.expanduser("~"), ".config", "systemd", "user")
STACK_DIR = os.environ.get("HERMES_STACK_DIR", os.path.join(HOME, "hermes-stack"))
COMPOSE_FILE = os.path.join(STACK_DIR, "docker-compose.yml")
INSTALL_DIR = os.environ.get("OLLIE_INSTALL_DIR", os.path.join(HOME, "ollie-hermes-install"))
ORCH_DIR = os.path.join(HOME, "ollie-hermes-orchestrator")
ORCH_URL = os.environ.get("ORCH_URL", "http://localhost:9123")
ORCH_ENV = os.environ.get("ORCH_ENV", os.path.join(HOME, ".config", "ollie-orchestrator", ".env"))
FLEET_ENV = os.environ.get("FLEET_ENV", os.path.join(HOME, ".config", "ollie-fleet", ".env"))
# Tear-down marker for the "fully disabled" state: present => the daemon exits
# before any network call and stays silent across reboots. Lives beside the env.
DISABLED_MARKER = os.path.join(os.path.dirname(FLEET_ENV), "disabled")


# ---------------------------------------------------------------- plumbing

def emit(obj):
    """Print the verb's single JSON result object."""
    print(json.dumps(obj))


def fail(msg, code=1):
    """Print {"error": ...} and exit non-zero."""
    print(json.dumps({"error": msg}))
    sys.exit(code)


def event(**kw):
    """Print one NDJSON progress event (flushed so SSH relays it live)."""
    print(json.dumps(kw), flush=True)


def run_cmd(args, timeout=30, input_text=None):
    """Run a command; return (rc, stdout, stderr). Never raises on non-zero."""
    try:
        p = subprocess.run(args, capture_output=True, text=True,
                           timeout=timeout, input=input_text)
        return p.returncode, p.stdout, p.stderr
    except FileNotFoundError:
        return 127, "", "%s: not found" % args[0]
    except subprocess.TimeoutExpired:
        return 124, "", "%s: timed out after %ss" % (args[0], timeout)


def read_env_file(path):
    """Parse KEY=VALUE lines (quotes stripped); missing file -> {}."""
    env = {}
    try:
        with open(path, encoding="utf-8") as f:
            for line in f:
                line = line.strip()
                if not line or line.startswith("#") or "=" not in line:
                    continue
                k, _, v = line.partition("=")
                k = k.strip()
                if not k:
                    continue
                env[k] = v.strip().strip("'\"")
    except OSError:
        pass
    return env


# ------------------------------------------------------- orchestrator client

def orch_key():
    key = read_env_file(ORCH_ENV).get("ORCHESTRATOR_KEY", "")
    if not key:
        raise RuntimeError("no ORCHESTRATOR_KEY in %s" % ORCH_ENV)
    return key


def orch_request(method, path, body=None, timeout=30):
    """JSON request to the local orchestrator -> (status, parsed_or_None, raw)."""
    req = urllib.request.Request(
        ORCH_URL + path, method=method,
        data=json.dumps(body).encode() if body is not None else None,
        headers={"Authorization": "Bearer " + orch_key(),
                 "Content-Type": "application/json",
                 "User-Agent": USER_AGENT})
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            raw = resp.read().decode()
            return resp.status, (json.loads(raw) if raw.strip() else None), raw
    except urllib.error.HTTPError as e:
        return e.code, None, e.read().decode(errors="replace")
    except urllib.error.URLError as e:
        return None, None, str(e)


def orch_stream(method, path, body, timeout=600):
    """Send a request and relay the orchestrator's SSE stream as NDJSON.
    Returns the last event object (or None if the stream was empty)."""
    req = urllib.request.Request(
        ORCH_URL + path, method=method,
        data=json.dumps(body).encode() if body is not None else None,
        headers={"Authorization": "Bearer " + orch_key(),
                 "Content-Type": "application/json",
                 "User-Agent": USER_AGENT})
    last = None
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            for line in resp:
                line = line.decode().strip()
                if not line.startswith("data:"):
                    continue
                try:
                    obj = json.loads(line[5:].strip())
                except ValueError:
                    continue
                last = obj
                event(**obj)
    except urllib.error.HTTPError as e:
        body = e.read().decode(errors="replace")[:200]
        last = {"event": "error", "error": "orchestrator HTTP %s: %s" % (e.code, body)}
        event(**last)
    except (urllib.error.URLError, OSError) as e:
        last = {"event": "error", "error": "orchestrator unreachable: %s" % e}
        event(**last)
    return last


# ----------------------------------------------------------- health collectors

def _read_file(path):
    with open(path) as f:
        return f.read()


def _proc_stat_cpu():
    """-> (idle_ticks, total_ticks) from the aggregate cpu line."""
    nums = [int(x) for x in _read_file("/proc/stat").splitlines()[0].split()[1:]]
    idle = nums[3] + (nums[4] if len(nums) > 4 else 0)
    return idle, sum(nums)


def get_cpu_percent():
    i1, t1 = _proc_stat_cpu()
    time.sleep(0.25)
    i2, t2 = _proc_stat_cpu()
    dt = t2 - t1
    return round(100 * (1 - (i2 - i1) / dt)) if dt > 0 else 0


def get_memory_mb():
    """-> (used_mb, total_mb) using MemAvailable semantics."""
    info = {}
    for line in _read_file("/proc/meminfo").splitlines():
        k, _, v = line.partition(":")
        if v.strip():
            info[k.strip()] = int(v.strip().split()[0])  # kB
    total = info.get("MemTotal", 0) // 1024
    avail = info.get("MemAvailable", 0) // 1024
    if not info.get("MemAvailable"):
        raise RuntimeError("MemAvailable missing from /proc/meminfo")
    return total - avail, total


def get_system():
    used_mb, total_mb = get_memory_mb()
    du = shutil.disk_usage("/")
    return {
        "cpuPercent": get_cpu_percent(),
        "ramUsedMb": used_mb,
        "ramTotalMb": total_mb,
        "diskUsedGb": round(du.used / 1e9, 1),
        "diskTotalGb": round(du.total / 1e9, 1),
    }


def get_units():
    rc, out, err = run_cmd(["systemctl", "--user", "list-units", "--all",
                            "--no-legend", "--plain",
                            "hermes-*", "ollie-orchestrator*"])
    if rc != 0:
        raise RuntimeError("systemctl failed: %s" % err.strip())
    units = []
    for line in out.splitlines():
        parts = line.split()
        if len(parts) >= 3 and parts[0].endswith(".service"):
            units.append({"unit": parts[0], "active": parts[2]})
    return units


def get_containers():
    rc, out, err = run_cmd(["docker", "compose", "-f", COMPOSE_FILE,
                            "ps", "-a", "--format", "json"])
    if rc != 0:
        raise RuntimeError("docker compose ps failed: %s" % err.strip())
    stripped = out.strip()
    if not stripped:
        return []
    if stripped.startswith("["):  # compose v2.21+ emits a single JSON array
        items = json.loads(stripped)
    else:  # older compose emits one JSON object per line
        items = [json.loads(l) for l in stripped.splitlines() if l.strip()]
    return [{"name": c.get("Service", ""), "state": c.get("State", ""),
             "status": c.get("Status", "")} for c in items]


def get_versions():
    versions = {"fleetctl": VERSION}
    rc, out, _ = run_cmd(["hermes", "--version"], timeout=15)
    versions["hermes"] = out.strip() if rc == 0 and out.strip() else "unknown"
    return versions


def get_agents_summary():
    status, parsed, raw = orch_request("GET", "/v1/agents")
    if status != 200:
        raise RuntimeError("orchestrator /v1/agents returned HTTP %s: %s" % (status, raw[:200]))
    if parsed is None:
        raise RuntimeError("orchestrator /v1/agents: empty body")
    return parsed.get("agents", [])


def build_health():
    health = {"fleetctlVersion": VERSION,
              "collectedAt": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())}
    errors = []
    for key, name in (("system", "get_system"), ("units", "get_units"),
                      ("containers", "get_containers"), ("versions", "get_versions"),
                      ("agents", "get_agents_summary")):
        try:
            # globals() is the live module dict, so tests can monkeypatch collectors
            health[key] = globals()[name]()
        except Exception as e:  # collectors degrade independently
            health[key] = None
            errors.append("%s: %s" % (key, e))
    health["errors"] = errors
    return health


def cmd_health(args):
    emit(build_health())


def _payload(args):
    """JSON body from --json or stdin."""
    raw = args.json if args.json is not None else sys.stdin.read()
    try:
        return json.loads(raw)
    except ValueError as e:
        fail("invalid JSON payload: %s" % e, 2)


def cmd_agents(args):
    if args.action == "list":
        status, parsed, raw = orch_request("GET", "/v1/agents")
        if status != 200 or parsed is None:
            fail("orchestrator HTTP %s: %s" % (status, raw[:200]))
        emit(parsed)
    elif args.action == "get":
        status, parsed, raw = orch_request("GET", "/v1/agents/%s" % args.id)
        if status != 200 or parsed is None:
            fail("orchestrator HTTP %s: %s" % (status, raw[:200]))
        emit(parsed)
    elif args.action == "create":
        last = orch_stream("POST", "/v1/agents", _payload(args))
        if not last or last.get("event") != "done":
            sys.exit(1)
    elif args.action == "update":
        status, parsed, raw = orch_request("PATCH", "/v1/agents/%s" % args.id, _payload(args))
        if status != 200:
            fail("orchestrator HTTP %s: %s" % (status, raw[:200]))
        emit(parsed if parsed is not None else {"updated": args.id})
    elif args.action == "delete":
        status, _, raw = orch_request("DELETE", "/v1/agents/%s" % args.id)
        if status not in (204, 404):  # delete is idempotent
            fail("orchestrator HTTP %s: %s" % (status, raw[:200]))
        emit({"deleted": args.id})
    elif args.action == "set-identity":
        status, parsed, raw = orch_request("POST", "/v1/agents/%s/identity" % args.id, _payload(args))
        if status != 200:
            fail("orchestrator HTTP %s: %s" % (status, raw[:200]))
        emit(parsed if parsed is not None else {"ok": True})


DOCKER_SERVICES = {"cortex": "cortex", "frontend": "dashboard"}


def resolve_target(target):
    """Map a restart/logs target -> (systemd_units, compose_services).
    Raises ValueError for unknown targets."""
    if target == "stack":
        units = [u["unit"] for u in get_units() if u.get("active") == "active"]
        return units, ["cortex", "dashboard"]
    if target in DOCKER_SERVICES:
        return [], [DOCKER_SERVICES[target]]
    if target == "orchestrator":
        return ["ollie-orchestrator.service"], []
    for base in ("gateway", "dashboard"):
        if target == base:
            return ["hermes-%s.service" % base], []
        if target.startswith(base + "-"):
            return ["hermes-%s.service" % target], []
    raise ValueError("unknown target: %s (expected gateway[-name], dashboard[-name], "
                     "orchestrator, cortex, frontend, or stack)" % target)


def cmd_restart(args):
    try:
        units, services = resolve_target(args.target)
    except ValueError as e:
        fail(str(e), 2)
    results = []
    for u in units:
        rc, _, err = run_cmd(["systemctl", "--user", "restart", u], timeout=60)
        results.append({"target": u, "ok": rc == 0,
                        "error": err.strip() or "exit %s" % rc if rc != 0 else None})
    for s in services:
        rc, _, err = run_cmd(["docker", "compose", "-f", COMPOSE_FILE,
                              "restart", s], timeout=120)
        results.append({"target": "compose:%s" % s, "ok": rc == 0,
                        "error": err.strip() or "exit %s" % rc if rc != 0 else None})
    emit({"restarted": results})
    if not all(r["ok"] for r in results):
        sys.exit(1)


def cmd_logs(args):
    if args.service == "stack":
        fail("'stack' is not a valid logs target; specify a single service", 2)
    if args.service in DOCKER_SERVICES:
        rc, out, err = run_cmd(["docker", "compose", "-f", COMPOSE_FILE, "logs",
                                "--no-color", "--tail", str(args.lines),
                                DOCKER_SERVICES[args.service]], timeout=30)
    else:
        try:
            units, _ = resolve_target(args.service)
        except ValueError as e:
            fail(str(e), 2)
        rc, out, err = run_cmd(["journalctl", "--user", "-u", units[0],
                                "-n", str(args.lines), "--no-pager",
                                "-o", "short-iso"], timeout=30)
    if rc != 0:
        fail("logs failed for %s: %s" % (args.service, err.strip()))
    emit({"service": args.service, "lines": out.splitlines()})


def _step_cmd(args_list, timeout, input_text=None):
    """Run one update step -> (ok, short_detail)."""
    rc, out, err = run_cmd(args_list, timeout=timeout, input_text=input_text)
    return rc == 0, (err.strip() or out.strip())[-500:]


def cmd_update(args):
    component = args.component
    steps = []
    if component in ("hermes", "all"):
        steps += [
            ("git-pull-install-repo", ["git", "-C", INSTALL_DIR, "pull", "--ff-only"], 120),
            # Reinstall fleetctl from the freshly-pulled repo so the running binary
            # stays in sync with the template on every hermes update.
            ("reinstall-fleetctl", ["bash", os.path.join(INSTALL_DIR, "scripts", "10-install-fleetctl.sh")], 60),
            ("hermes-update", ["hermes", "update"], 900),
            # hermes update resets ~/.hermes/hermes-agent — re-apply the stack pieces it wipes:
            ("reinstall-cortex-plugin", ["bash", os.path.join(INSTALL_DIR, "scripts", "04-install-cortex-plugin.sh")], 300),
            ("repatch-cron-brain", ["bash", os.path.join(INSTALL_DIR, "scripts", "07-patch-cron-brain.sh")], 120),
            ("reinstall-souls", ["bash", os.path.join(INSTALL_DIR, "scripts", "08-install-souls.sh")], 120),
        ]
    if component in ("stack", "all"):
        steps += [
            ("compose-pull", ["docker", "compose", "-f", COMPOSE_FILE, "pull"], 600),
            ("compose-up", ["docker", "compose", "-f", COMPOSE_FILE, "up", "-d"], 300),
        ]
    if component in ("orchestrator", "all"):
        steps += [
            ("git-pull-orchestrator", ["git", "-C", ORCH_DIR, "pull", "--ff-only"], 120),
            ("pip-install", [os.path.join(ORCH_DIR, ".venv", "bin", "pip"),
                             "install", "-q", "-r",
                             os.path.join(ORCH_DIR, "requirements.txt")], 600),
            ("restart-orchestrator", ["systemctl", "--user", "restart", "ollie-orchestrator"], 60),
        ]
    for name, cmd_args, timeout in steps:
        event(event="progress", step=name)
        # hermes update prompts interactively (same CLI behavior 02-install-hermes.sh
        # works around by piping "y"); answer yes so it can't hang to the timeout.
        ok, detail = _step_cmd(cmd_args, timeout,
                               input_text="y\ny\ny\ny\ny\n" if name == "hermes-update" else None)
        if not ok:
            event(event="error", step=name, error=detail)
            sys.exit(1)
    event(event="done", component=component)


# ----------------------------------------------------------- sync-agents helpers

def list_profiles():
    """Named profiles from ~/.hermes/profiles/ (excludes 'default')."""
    if not os.path.isdir(PROFILES_DIR):
        return []
    return sorted(d for d in os.listdir(PROFILES_DIR)
                  if os.path.isdir(os.path.join(PROFILES_DIR, d)))


def get_service_port(service_name):
    """Parse --port N from a systemd unit's ExecStart. Returns None if absent."""
    rc, out, _ = run_cmd(["systemctl", "--user", "cat", service_name])
    if rc != 0:
        return None
    for line in out.splitlines():
        if not line.startswith("ExecStart="):
            continue
        parts = line.split()
        for i, token in enumerate(parts):
            if token == "--port" and i + 1 < len(parts):
                try:
                    return int(parts[i + 1])
                except ValueError:
                    pass
    return None


def is_service_active(service_name):
    rc, out, _ = run_cmd(["systemctl", "--user", "is-active", service_name])
    return rc == 0 and out.strip() == "active"


def read_agents_json():
    raw = read_env_file(os.path.join(STACK_DIR, ".env")).get("AGENTS_JSON", "[]")
    try:
        return json.loads(raw)
    except ValueError:
        return []


def write_stack_env_key(key, value):
    """Update a single KEY=value line in ~/hermes-stack/.env atomically."""
    env_path = os.path.join(STACK_DIR, ".env")
    try:
        with open(env_path, encoding="utf-8") as f:
            lines = f.readlines()
    except OSError:
        lines = []
    new_line = "%s=%s\n" % (key, value)
    replaced = False
    new_lines = []
    for line in lines:
        if line.startswith("%s=" % key):
            new_lines.append(new_line)
            replaced = True
        else:
            new_lines.append(line)
    if not replaced:
        new_lines.append(new_line)
    tmp = env_path + ".tmp"
    with open(tmp, "w", encoding="utf-8") as f:
        f.writelines(new_lines)
    os.replace(tmp, env_path)


def read_profile_gateway_port(profile):
    """Read gateway.port from the profile's config.yaml. Returns None if absent."""
    config_path = os.path.join(PROFILES_DIR, profile, "config.yaml")
    try:
        with open(config_path) as f:
            in_gateway = False
            for line in f:
                stripped = line.strip()
                if stripped == "gateway:":
                    in_gateway = True
                    continue
                if in_gateway:
                    if stripped.startswith("port:"):
                        try:
                            return int(stripped.split(":", 1)[1].strip())
                        except ValueError:
                            pass
                    if line and not line[0].isspace():
                        in_gateway = False
    except OSError:
        pass
    return None


def scan_used_ports(service_glob):
    """Return the set of ports used by all units matching a glob (e.g. hermes-gateway-*.service)."""
    used = set()
    if os.path.isdir(SYSTEMD_USER_DIR):
        for fname in os.listdir(SYSTEMD_USER_DIR):
            if fname.endswith(".service") and (
                fname.startswith("hermes-gateway-") if "gateway" in service_glob
                else fname.startswith("hermes-dashboard-")
            ):
                p = get_service_port(fname)
                if p:
                    used.add(p)
    return used


def _next_free_port(base, used):
    p = base
    while p in used:
        p += 1
    return p


def _create_gateway_unit(profile):
    """Create, enable and start a hermes-gateway-{profile}.service. Returns port or None."""
    unit_name = "hermes-gateway-%s.service" % profile
    unit_path = os.path.join(SYSTEMD_USER_DIR, unit_name)
    if os.path.exists(unit_path):
        return None  # unit file already exists but get_service_port failed — leave it alone

    # Port: read from profile config.yaml first, then auto-assign
    port = read_profile_gateway_port(profile)
    if port is None:
        used = scan_used_ports("gateway") | {DEFAULT_GATEWAY_PORT}
        port = _next_free_port(GATEWAY_BASE_PORT, used)

    venv_bin = os.path.dirname(VENV_PYTHON)
    node_bin = os.path.join(HERMES_DIR, "node", "bin")
    node_modules_bin = os.path.join(HERMES_DIR, "hermes-agent", "node_modules", ".bin")
    local_bin = os.path.join(HOME, ".local", "bin")
    path_env = ":".join(filter(os.path.isdir, [venv_bin, node_modules_bin, node_bin, local_bin,
                                                "/usr/local/sbin", "/usr/local/bin", "/usr/sbin",
                                                "/usr/bin", "/sbin", "/bin"]))

    profile_dir = os.path.join(PROFILES_DIR, profile)
    unit = (
        "[Unit]\n"
        "Description=Hermes Agent Gateway - %s\n"
        "After=network-online.target\n"
        "Wants=network-online.target\n"
        "StartLimitIntervalSec=0\n"
        "\n"
        "[Service]\n"
        "Type=simple\n"
        "ExecStart=%s -m hermes_cli.main --profile %s gateway run\n"
        "WorkingDirectory=%s\n"
        'Environment="PATH=%s"\n'
        'Environment="VIRTUAL_ENV=%s"\n'
        'Environment="HERMES_HOME=%s"\n'
        "Restart=always\n"
        "RestartSec=5\n"
        "RestartForceExitStatus=75\n"
        "KillMode=mixed\n"
        "KillSignal=SIGTERM\n"
        "ExecReload=/bin/kill -USR1 $MAINPID\n"
        "TimeoutStopSec=210\n"
        "StandardOutput=journal\n"
        "StandardError=journal\n"
        "\n"
        "[Install]\n"
        "WantedBy=default.target\n"
    ) % (profile, VENV_PYTHON, profile, profile_dir, path_env,
         os.path.dirname(venv_bin), profile_dir)

    os.makedirs(SYSTEMD_USER_DIR, exist_ok=True)
    with open(unit_path, "w") as f:
        f.write(unit)

    run_cmd(["systemctl", "--user", "daemon-reload"])
    rc, _, _ = run_cmd(["systemctl", "--user", "enable", "--now", unit_name], timeout=60)
    if rc != 0:
        try:
            os.unlink(unit_path)
        except OSError:
            pass
        return None
    return port


def _create_dashboard_unit(profile):
    """Create, enable and start a hermes-dashboard-{profile}.service. Returns port or None."""
    unit_name = "hermes-dashboard-%s.service" % profile
    unit_path = os.path.join(SYSTEMD_USER_DIR, unit_name)
    if os.path.exists(unit_path):
        return get_service_port(unit_name)  # already exists — return its port

    used = scan_used_ports("dashboard") | {DEFAULT_DASHBOARD_PORT}
    port = _next_free_port(DASHBOARD_BASE_PORT, used)

    hermes_shim = os.path.join(HOME, ".local", "bin", "hermes")
    unit = (
        "[Unit]\n"
        "Description=Hermes dashboard for %s\n"
        "After=network.target\n"
        "\n"
        "[Service]\n"
        "Type=simple\n"
        "Environment=PATH=%s/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin\n"
        "ExecStart=%s -p %s dashboard --host 0.0.0.0 --port %d --insecure --no-open\n"
        "Restart=always\n"
        "RestartSec=5\n"
        "StartLimitBurst=10\n"
        "StartLimitIntervalSec=60\n"
        "\n"
        "[Install]\n"
        "WantedBy=default.target\n"
    ) % (profile, HOME, hermes_shim, profile, port)

    os.makedirs(SYSTEMD_USER_DIR, exist_ok=True)
    with open(unit_path, "w") as f:
        f.write(unit)

    run_cmd(["systemctl", "--user", "daemon-reload"])
    rc, _, _ = run_cmd(["systemctl", "--user", "enable", "--now", unit_name], timeout=60)
    if rc != 0:
        try:
            os.unlink(unit_path)
        except OSError:
            pass
        return None
    return port


def cmd_sync_agents(args):
    """Reconcile AGENTS_JSON with running Hermes profiles and gateway/dashboard services.

    Ground truth: ~/.hermes/profiles/ (named profiles) + hermes-gateway.service
    (default profile). Adds missing AGENTS_JSON entries, optionally creates missing
    systemd units (--fix-gateways), and flags stale entries.
    """
    dry_run = getattr(args, "dry_run", False)
    fix = getattr(args, "fix_gateways", False)
    profiles_on_disk = list_profiles()
    current = read_agents_json()
    agents_by_id = {a["id"]: a for a in current}
    result = list(current)

    added = []
    unchanged = []
    needs_gateway = []   # profile dir exists but no gateway service
    needs_dashboard = [] # gateway ok but no dashboard service
    fixed_gateway = []   # gateway created by --fix-gateways
    fixed_dashboard = [] # dashboard created by --fix-gateways
    stale = []           # in AGENTS_JSON but profile dir gone

    # --- named profiles (from ~/.hermes/profiles/) ---
    for profile in profiles_on_disk:
        gw_port = get_service_port("hermes-gateway-%s.service" % profile)
        dash_port = get_service_port("hermes-dashboard-%s.service" % profile)

        # Create missing gateway service
        if gw_port is None:
            if fix and not dry_run:
                gw_port = _create_gateway_unit(profile)
                if gw_port is not None:
                    fixed_gateway.append(profile)
                else:
                    needs_gateway.append(profile)
            else:
                needs_gateway.append(profile)

        # Create missing dashboard service (independently of gateway)
        if gw_port is not None and dash_port is None:
            if fix and not dry_run:
                dash_port = _create_dashboard_unit(profile)
                if dash_port is not None:
                    fixed_dashboard.append(profile)
                else:
                    needs_dashboard.append(profile)
            else:
                needs_dashboard.append(profile)

        if gw_port is None:
            continue  # can't add to AGENTS_JSON without a gateway

        if profile in agents_by_id:
            # Already in AGENTS_JSON — patch dashboardUrl if we just created the dashboard
            if dash_port and not agents_by_id[profile].get("dashboardUrl"):
                for entry in result:
                    if entry["id"] == profile:
                        entry["dashboardUrl"] = "http://host.docker.internal:%d" % dash_port
                        break
            unchanged.append(profile)
            continue

        entry = {
            "id": profile,
            "name": profile,
            "gatewayUrl": "http://host.docker.internal:%d" % gw_port,
        }
        if dash_port:
            entry["dashboardUrl"] = "http://host.docker.internal:%d" % dash_port
        result.append(entry)
        added.append(profile)

    # --- default profile (hermes-gateway.service, no profiles/ entry) ---
    if "default" not in agents_by_id and is_service_active("hermes-gateway.service"):
        gw_port = get_service_port("hermes-gateway.service") or DEFAULT_GATEWAY_PORT
        dash_port = get_service_port("hermes-dashboard.service") or DEFAULT_DASHBOARD_PORT
        result.insert(0, {
            "id": "default",
            "name": "Ollie",
            "gatewayUrl": "http://host.docker.internal:%d" % gw_port,
            "dashboardUrl": "http://host.docker.internal:%d" % dash_port,
        })
        added.insert(0, "default")

    # --- stale entries (id in AGENTS_JSON but no profile dir on disk) ---
    disk_ids = set(profiles_on_disk) | {"default"}
    for agent in current:
        if agent["id"] not in disk_ids:
            stale.append(agent["id"])

    changed = bool(added or fixed_gateway or fixed_dashboard)
    restarted = False
    if changed and not dry_run:
        write_stack_env_key("AGENTS_JSON",
                            json.dumps(result, separators=(",", ":")))
        rc, _, _ = run_cmd(["systemctl", "--user", "restart",
                            "ollie-orchestrator"], timeout=30)
        restarted = rc == 0

    emit({
        "added": added,
        "fixed_gateway": fixed_gateway,
        "fixed_dashboard": fixed_dashboard,
        "unchanged": unchanged,
        "needs_gateway": needs_gateway,
        "needs_dashboard": needs_dashboard,
        "stale": stale,
        "orchestrator_restarted": restarted,
        "dry_run": dry_run,
    })


def post_json(url, token, payload, timeout=15):
    """POST JSON with a bearer token -> HTTP status (raises on network or HTTP error)."""
    req = urllib.request.Request(
        url, method="POST", data=json.dumps(payload).encode(),
        headers={"Authorization": "Bearer " + token,
                 "Content-Type": "application/json",
                 "User-Agent": USER_AGENT})
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        return resp.status


def clamp_interval(minutes):
    try:
        m = int(minutes)
    except (TypeError, ValueError):
        return DEFAULT_INTERVAL_MINUTES
    return max(MIN_INTERVAL_MINUTES, min(MAX_INTERVAL_MINUTES, m))


def health_beat_due(now_s, last_beat_s, interval_min, beat_now):
    if beat_now or last_beat_s is None:
        return True
    return (now_s - last_beat_s) >= interval_min * 60


def is_disabled():
    return os.path.exists(DISABLED_MARKER)


def set_disabled():
    os.makedirs(os.path.dirname(DISABLED_MARKER), exist_ok=True)
    with open(DISABLED_MARKER, "w") as f:
        f.write("disabled by fleet\n")


def clear_disabled():
    try:
        os.remove(DISABLED_MARKER)
    except FileNotFoundError:
        pass


def get_control(url, token, timeout=15):
    """POST /heartbeat/control -> dict config, or None on any failure."""
    req = urllib.request.Request(
        url.rstrip("/") + "/heartbeat/control", method="POST", data=b"{}",
        headers={"Authorization": "Bearer " + token,
                 "Content-Type": "application/json",
                 "User-Agent": USER_AGENT})
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            return json.loads(resp.read().decode())
    except (urllib.error.URLError, OSError, ValueError):
        return None


def collect_backup_paths():
    """Files worth preserving: session DBs, configs, personas, OAuth tokens."""
    paths = []
    for rel in ("state.db", "config.yaml", "SOUL.md", "auth.json"):
        p = os.path.join(HERMES_DIR, rel)
        if os.path.isfile(p):
            paths.append(p)
    if os.path.isdir(PROFILES_DIR):
        for prof in sorted(os.listdir(PROFILES_DIR)):
            for rel in ("state.db", "config.yaml", "SOUL.md"):
                p = os.path.join(PROFILES_DIR, prof, rel)
                if os.path.isfile(p):
                    paths.append(p)
    return paths


def cmd_backup(args):
    if sys.stdout.isatty():
        fail("backup streams a tarball; redirect stdout "
             "(e.g. ollie-fleetctl backup > backup.tgz)", 2)
    staging = tempfile.mkdtemp(prefix="fleet-backup-")
    try:
        # Cortex DB snapshot via sqlite's online backup API (best-effort; the
        # container may be down — the rest of the backup still proceeds).
        # The python-slim image has no sqlite3 CLI, so go through python.
        run_cmd(["docker", "exec", "cortex", "python", "-c",
                 "import sqlite3; src = sqlite3.connect('/data/cortex.db'); "
                 "dst = sqlite3.connect('/data/cortex-snapshot.db'); "
                 "src.backup(dst); dst.close(); src.close()"], timeout=120)
        run_cmd(["docker", "cp", "cortex:/data/cortex-snapshot.db", staging],
                timeout=120)
        run_cmd(["docker", "exec", "cortex", "rm", "-f",
                 "/data/cortex-snapshot.db"], timeout=30)
        paths = collect_backup_paths()
        snap = os.path.join(staging, "cortex-snapshot.db")
        if os.path.isfile(snap):
            paths.append(snap)
        if not paths:
            fail("nothing to back up (no state.db/config/SOUL files found)")
        # Once tar starts, stdout IS the archive — nothing else may write to it
        # (no emit/fail/print past this line, or the tarball is corrupted).
        rc = subprocess.call(["tar", "czf", "-", "--absolute-names"] + paths,
                             stdout=sys.stdout.buffer if hasattr(sys.stdout, "buffer") else sys.stdout)
        sys.exit(rc)
    finally:
        shutil.rmtree(staging, ignore_errors=True)


def cmd_heartbeat(args):
    env = read_env_file(FLEET_ENV)
    url, token = env.get("FLEET_URL", ""), env.get("FLEET_TOKEN", "")
    if not url or not token:
        # Pre-enrollment no-op: the timer is installed before the box is enrolled.
        emit({"skipped": "not enrolled (%s lacks FLEET_URL/FLEET_TOKEN)" % FLEET_ENV})
        return
    payload = {"health": build_health()}
    try:
        status = post_json(url.rstrip("/") + "/heartbeat", token, payload)
        emit({"posted": True, "status": status})
    except urllib.error.HTTPError as e:
        fail("heartbeat rejected: HTTP %s" % e.code)
    except (urllib.error.URLError, OSError) as e:
        fail("heartbeat failed: %s" % e)


def daemon_tick(env, last_beat_s, now_s):
    """One control-poll + optional health beat. Returns the new last_beat_s
    (seconds), unchanged last_beat_s, or the string "DISABLED" to stop."""
    url, token = env.get("FLEET_URL", ""), env.get("FLEET_TOKEN", "")
    if not url or not token:
        return last_beat_s  # not enrolled yet
    cfg = get_control(url, token)
    if cfg is None:
        return last_beat_s  # transient failure: keep last-known behaviour
    state = cfg.get("state", "active")
    if state == "disabled":
        set_disabled()
        return "DISABLED"
    if state == "paused":
        return last_beat_s
    interval = clamp_interval(cfg.get("intervalMinutes", DEFAULT_INTERVAL_MINUTES))
    if health_beat_due(now_s, last_beat_s, interval, bool(cfg.get("beatNow"))):
        try:
            post_json(url.rstrip("/") + "/heartbeat", token, {"health": build_health()})
            return now_s
        except (urllib.error.URLError, urllib.error.HTTPError, OSError) as e:
            sys.stderr.write("heartbeat beat failed: %s\n" % e)
            return last_beat_s
    return last_beat_s


def cmd_heartbeat_daemon(args):
    # A disabled box must never touch the network: bail before reading anything.
    if is_disabled():
        emit({"daemon": "disabled (marker present); exiting"})
        return
    last_beat_s = None
    while True:
        env = read_env_file(FLEET_ENV)
        now_s = int(time.time())
        result = daemon_tick(env, last_beat_s, now_s)
        if result == "DISABLED":
            emit({"daemon": "disabled by fleet; exiting"})
            return
        last_beat_s = result
        if getattr(args, "once", False):
            return
        time.sleep(CONTROL_POLL_SECONDS)


# -------------------------------------------------------------------- main

def main(argv=None):
    p = argparse.ArgumentParser(prog="ollie-fleetctl",
                                description="Management verbs for the Ollie/Hermes stack")
    sub = p.add_subparsers(dest="verb", required=True)
    sub.add_parser("version", help="fleetctl version")
    sub.add_parser("health", help="one-shot stack health snapshot (JSON)")
    a = sub.add_parser("agents", help="agent CRUD via the local orchestrator")
    a.add_argument("action", choices=["list", "get", "create", "update",
                                      "delete", "set-identity"])
    a.add_argument("id", nargs="?", help="agent id (required except for list/create)")
    a.add_argument("--json", help="JSON payload; omit to read from stdin")
    r = sub.add_parser("restart", help="restart a service or the whole stack")
    r.add_argument("target",
                   help="gateway[-name] | dashboard[-name] | orchestrator | cortex | frontend | stack")
    l = sub.add_parser("logs", help="recent logs for one service")
    l.add_argument("service", help="same targets as restart (except stack)")
    l.add_argument("-n", "--lines", type=int, default=200)
    u = sub.add_parser("update", help="update stack components (streams NDJSON progress)")
    u.add_argument("component", nargs="?", default="all",
                   choices=["hermes", "stack", "orchestrator", "all"])
    sa = sub.add_parser("sync-agents",
                        help="reconcile AGENTS_JSON with running Hermes profiles; "
                             "updates ~/hermes-stack/.env and restarts orchestrator")
    sa.add_argument("--dry-run", action="store_true",
                    help="show what would change without writing anything")
    sa.add_argument("--fix-gateways", action="store_true",
                    help="create missing gateway/dashboard systemd units for profiles on disk")
    sub.add_parser("heartbeat", help="POST health to the fleet dashboard (no-op until enrolled)")
    d = sub.add_parser("heartbeat-daemon", help="run the heartbeat control loop (systemd service)")
    d.add_argument("--once", action="store_true", help="run a single tick and exit (debug/test)")
    sub.add_parser("backup", help="stream a tarball of state DBs, configs, personas, "
                                  "and auth.json (contains live OAuth tokens — store securely)")

    args = p.parse_args(argv)

    # systemctl --user needs the user bus even when invoked via sudo -u / cron
    # without a login session (same fallback scripts 02/03/05/07 use).
    if hasattr(os, "getuid"):
        os.environ.setdefault("XDG_RUNTIME_DIR", "/run/user/%d" % os.getuid())

    try:
        if args.verb == "version":
            emit({"fleetctl": VERSION})
        elif args.verb == "health":
            cmd_health(args)
        elif args.verb == "agents":
            if args.action in ("get", "update", "delete", "set-identity") and not args.id:
                p.error("agents %s requires an agent id" % args.action)
            cmd_agents(args)
        elif args.verb == "restart":
            cmd_restart(args)
        elif args.verb == "logs":
            cmd_logs(args)
        elif args.verb == "update":
            cmd_update(args)
        elif args.verb == "heartbeat":
            cmd_heartbeat(args)
        elif args.verb == "heartbeat-daemon":
            cmd_heartbeat_daemon(args)
        elif args.verb == "sync-agents":
            cmd_sync_agents(args)
        elif args.verb == "backup":
            cmd_backup(args)
    except SystemExit:
        raise
    except Exception as e:
        # The contract promises {"error": ...} on stdout for every failure —
        # an uncaught traceback on stderr is invisible to the Fleet dashboard.
        fail("%s: %s" % (type(e).__name__, e))


if __name__ == "__main__":
    main()
